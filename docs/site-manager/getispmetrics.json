{
  "h1": "Get ISP Metrics",
  "method": "GET",
  "path": "/v1/isp-metrics/{type}",
  "description": "Retrieves ISP metrics data for all sites linked to the UI account's API key. 5-minute interval metrics are available for at least 24 hours, and 1-hour interval metrics are available for at least 30 days.",
  "pathParameters": [
    {
      "name": "type",
      "required": true,
      "type": "string",
      "description": "Specifies whether metrics are returned using `5m` or `1h` intervals",
      "discriminator": null,
      "children": []
    }
  ],
  "queryParameters": [
    {
      "name": "beginTimestamp",
      "required": false,
      "type": "string",
      "description": "The earliest timestamp to retrieve data from (RFC3339 format)",
      "discriminator": null,
      "children": []
    },
    {
      "name": "endTimestamp",
      "required": false,
      "type": "string",
      "description": "The latest timestamp to retrieve data up to (RFC3339 format)",
      "discriminator": null,
      "children": []
    },
    {
      "name": "duration",
      "required": false,
      "type": "string",
      "description": "Specifies the time range of metrics to retrieve, starting from when the request is made. Supports `24h` for 5-minute metrics, and `7d` or `30d` for 1-hour metrics. This parameter **cannot** be used with `beginTimestamp` or `endTimestamp`.",
      "discriminator": null,
      "children": []
    }
